{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Signals Content",
  "description": "Phase 4 industry signals and drafted social posts",
  "type": "object",
  "required": ["bus_version", "date", "generated_by", "signals_found", "selected_signal", "linkedin_draft"],
  "properties": {
    "bus_version": {
      "type": "integer",
      "const": 1
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "generated_by": {
      "type": "string"
    },
    "signals_found": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "source", "url"],
        "properties": {
          "title": { "type": "string" },
          "source": { "type": "string" },
          "url": { "type": "string" },
          "summary": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium"]
          },
          "published": { "type": "string" }
        }
      }
    },
    "selected_signal": {
      "type": "object",
      "required": ["title", "source", "url", "reason_selected"],
      "properties": {
        "title": { "type": "string" },
        "source": { "type": "string" },
        "url": { "type": "string" },
        "reason_selected": { "type": "string" }
      }
    },
    "linkedin_draft": {
      "type": "string"
    },
    "x_draft": {
      "type": "string"
    },
    "reddit_draft": {
      "type": ["object", "null"],
      "properties": {
        "subreddit": { "type": "string" },
        "thread_url": { "type": "string" },
        "comment": { "type": "string" }
      }
    },
    "medium_hook": {
      "type": ["object", "null"],
      "properties": {
        "title": { "type": "string" },
        "angle": { "type": "string" }
      }
    },
    "instagram_draft": {
      "type": ["string", "null"]
    },
    "tiktok_draft": {
      "type": ["string", "null"]
    }
  }
}
