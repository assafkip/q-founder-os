{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Calendar Pull",
  "description": "Phase 1 calendar events for today and this week",
  "type": "object",
  "required": ["bus_version", "date", "generated_by", "today", "this_week"],
  "properties": {
    "bus_version": {
      "type": "integer",
      "const": 1
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "generated_by": {
      "type": "string"
    },
    "today": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "time"],
        "properties": {
          "title": { "type": "string" },
          "time": { "type": "string" },
          "attendees": {
            "type": "array",
            "items": { "type": "string" }
          },
          "link": { "type": "string" }
        }
      }
    },
    "this_week": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "date", "time"],
        "properties": {
          "title": { "type": "string" },
          "date": { "type": "string" },
          "time": { "type": "string" },
          "attendees": {
            "type": "array",
            "items": { "type": "string" }
          },
          "link": { "type": "string" }
        }
      }
    }
  }
}
