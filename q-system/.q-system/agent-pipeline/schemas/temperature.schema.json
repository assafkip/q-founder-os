{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Temperature Scoring",
  "description": "Phase 5 prospect temperature scores from deterministic scoring script",
  "type": "object",
  "required": ["bus_version", "date", "generated_by", "scores", "summary"],
  "properties": {
    "bus_version": {
      "type": "integer",
      "const": 1
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "generated_by": {
      "type": "string"
    },
    "scores": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "raw_score", "temperature"],
        "properties": {
          "name": { "type": "string" },
          "notion_id": { "type": "string" },
          "raw_score": { "type": "number" },
          "temperature": {
            "type": "string",
            "enum": ["Hot", "Warm", "Cool", "Cold"]
          },
          "signals": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string" },
                "weight": { "type": "integer" },
                "date": { "type": "string" }
              }
            }
          },
          "flag_auto_close": { "type": "boolean" }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["hot", "warm", "cool", "cold"],
      "properties": {
        "hot": { "type": "integer" },
        "warm": { "type": "integer" },
        "cool": { "type": "integer" },
        "cold": { "type": "integer" },
        "flagged_for_close": { "type": "integer" }
      }
    }
  }
}
