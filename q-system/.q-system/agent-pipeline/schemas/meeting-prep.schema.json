{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Meeting Prep",
  "description": "Phase 2 meeting preparation with context and talk points",
  "type": "object",
  "required": ["bus_version", "date", "generated_by", "meetings"],
  "properties": {
    "bus_version": {
      "type": "integer",
      "const": 1
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "generated_by": {
      "type": "string"
    },
    "meetings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "time", "attendees", "prep"],
        "properties": {
          "title": { "type": "string" },
          "time": { "type": "string" },
          "attendees": {
            "type": "array",
            "items": { "type": "string" }
          },
          "prep": {
            "type": "object",
            "required": ["who", "talk_points"],
            "properties": {
              "who": { "type": "string" },
              "last_interaction": {
                "type": "object",
                "properties": {
                  "date": { "type": "string" },
                  "summary": { "type": "string" }
                }
              },
              "open_items": {
                "type": "array",
                "items": { "type": "string" }
              },
              "talk_points": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
