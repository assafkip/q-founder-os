{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Engagement Hitlist",
  "description": "Phase 5 copy-paste-ready engagement actions",
  "type": "object",
  "required": ["bus_version", "date", "generated_by", "total_actions", "actions"],
  "properties": {
    "bus_version": {
      "type": "integer",
      "const": 1
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "generated_by": {
      "type": "string"
    },
    "total_actions": {
      "type": "integer",
      "minimum": 0
    },
    "connection_requests_count": {
      "type": "integer",
      "minimum": 0
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["rank", "contact_name", "platform", "action_type", "copy"],
        "properties": {
          "rank": { "type": "integer" },
          "contact_name": { "type": "string" },
          "contact_title": { "type": "string" },
          "platform": {
            "type": "string",
            "enum": ["LinkedIn", "X", "Reddit"]
          },
          "action_type": {
            "type": "string",
            "enum": ["comment", "DM", "connection_request"]
          },
          "relationship_stage": { "type": "string" },
          "temperature": { "type": "string" },
          "post_url": { "type": "string" },
          "profile_url": { "type": "string" },
          "post_full_text": { "type": "string" },
          "copy": { "type": "string" },
          "rationale": { "type": "string" }
        }
      }
    }
  }
}
