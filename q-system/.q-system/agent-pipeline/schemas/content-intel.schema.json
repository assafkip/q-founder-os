{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Content Intelligence",
  "description": "Phase 3 weekly content engagement analysis (Mondays only)",
  "type": "object",
  "required": ["date"],
  "oneOf": [
    {
      "required": ["skipped"],
      "properties": {
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "skipped": { "type": "boolean", "const": true },
        "reason": { "type": "string" }
      }
    },
    {
      "required": ["bus_version", "generated_by", "platforms", "cross_platform", "recommendations"],
      "properties": {
        "bus_version": { "type": "integer", "const": 1 },
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "generated_by": { "type": "string" },
        "platforms": {
          "type": "object",
          "properties": {
            "linkedin": { "$ref": "#/$defs/platform_metrics" },
            "x": { "$ref": "#/$defs/platform_metrics" },
            "reddit": { "$ref": "#/$defs/platform_metrics" },
            "medium": { "$ref": "#/$defs/platform_metrics" },
            "substack": { "$ref": "#/$defs/platform_metrics" },
            "instagram": { "$ref": "#/$defs/platform_metrics" },
            "tiktok": { "$ref": "#/$defs/platform_metrics" }
          }
        },
        "cross_platform": {
          "type": "object",
          "properties": {
            "best_theme": { "type": "string" },
            "best_platform": { "type": "string" },
            "content_type_breakdown": {
              "type": "object",
              "properties": {
                "thought_leadership": { "type": "integer" },
                "tactical": { "type": "integer" },
                "personal": { "type": "integer" },
                "case_study": { "type": "integer" }
              }
            }
          }
        },
        "recommendations": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  ],
  "$defs": {
    "platform_metrics": {
      "type": "object",
      "required": ["posts_analyzed", "avg_engagement_rate"],
      "properties": {
        "posts_analyzed": { "type": "integer" },
        "avg_engagement_rate": { "type": "number" },
        "top_3": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text_preview": { "type": "string" },
              "url": { "type": "string" },
              "engagement_rate": { "type": "number" }
            }
          }
        },
        "bottom_3": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text_preview": { "type": "string" },
              "url": { "type": "string" },
              "engagement_rate": { "type": "number" }
            }
          }
        },
        "top_theme": { "type": "string" },
        "top_hook_pattern": { "type": "string" }
      }
    }
  }
}
