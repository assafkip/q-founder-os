{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Energy Check",
  "description": "Phase 0 energy level and compression settings",
  "type": "object",
  "required": ["bus_version", "date", "generated_by", "level", "label", "compression"],
  "properties": {
    "bus_version": {
      "type": "integer",
      "const": 1
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "generated_by": {
      "type": "string"
    },
    "level": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "label": {
      "type": "string",
      "enum": ["wiped", "low", "okay", "good", "locked_in"]
    },
    "notes": {
      "type": ["string", "null"]
    },
    "compression": {
      "type": "object",
      "required": ["max_hitlist_actions", "skip_deep_focus", "batch_quick_wins_only"],
      "properties": {
        "max_hitlist_actions": {
          "type": "integer",
          "minimum": 3
        },
        "skip_deep_focus": { "type": "boolean" },
        "batch_quick_wins_only": { "type": "boolean" }
      }
    }
  }
}
