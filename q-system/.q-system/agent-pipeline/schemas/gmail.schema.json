{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gmail Pull",
  "description": "Phase 1 recent emails from the last 48 hours",
  "type": "object",
  "required": ["bus_version", "date", "generated_by", "emails", "flagged_count"],
  "properties": {
    "bus_version": {
      "type": "integer",
      "const": 1
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "generated_by": {
      "type": "string"
    },
    "emails": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["subject", "from", "date", "snippet", "already_replied", "flagged"],
        "properties": {
          "subject": { "type": "string" },
          "from": { "type": "string" },
          "date": { "type": "string" },
          "snippet": { "type": "string" },
          "already_replied": { "type": "boolean" },
          "flagged": { "type": "boolean" },
          "flag_reason": {
            "type": ["string", "null"],
            "enum": ["meeting", "demo", "intro", "investment", "pilot", "product", null]
          }
        }
      }
    },
    "flagged_count": {
      "type": "integer",
      "minimum": 0
    }
  }
}
