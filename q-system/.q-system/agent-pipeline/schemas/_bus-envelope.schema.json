{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bus Envelope",
  "description": "Shared envelope fields required in every bus file",
  "type": "object",
  "required": ["bus_version", "date", "generated_by"],
  "properties": {
    "bus_version": {
      "type": "integer",
      "const": 1
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "generated_by": {
      "type": "string"
    }
  }
}
