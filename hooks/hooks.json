{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '--- Pulling latest from remote ---' && git pull --rebase origin main 2>&1 || echo 'WARNING: git pull failed — check for conflicts or set upstream'"
          },
          {
            "type": "command",
            "command": "test -d \"${CLAUDE_PLUGIN_DATA}/.venv\" || (cd \"${CLAUDE_PLUGIN_ROOT}/kipi-mcp\" && uv sync --quiet)"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/q-system/hooks/sync-data.sh\" \"${CLAUDE_PLUGIN_DATA}\""
          },
          {
            "type": "command",
            "command": "KIPI_PLUGIN_DATA=\"${CLAUDE_PLUGIN_DATA}\" python3 \"${CLAUDE_PLUGIN_ROOT}/q-system/hooks/session-start.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/q-system/hooks/token-guard.py\""
          }
        ]
      }
    ]
  }
}
