# Secrets (local settings with real tokens)
.env
*.env
.claude/settings.local.json

# OS
.DS_Store
Thumbs.db

# Output (generated daily, don't commit)
q-system/output/*.html
q-system/output/drafts/*
q-system/output/lead-gen/*
q-system/output/design-partner/*
q-system/output/marketing/linkedin/*
!**/.gitkeep

# Session transcripts
*.jsonl
!q-system/memory/graph.jsonl

# Working memory (ephemeral, don't commit)
q-system/memory/working/*
!q-system/memory/working/.gitkeep
!q-system/memory/working/predictions.jsonl

CLAUDE.local.md

# Morning logs (generated at runtime)
q-system/output/morning-log-*.json

# Open loops (runtime state)
q-system/output/open-loops.json

# Bus data (inter-agent communication, per-session)
q-system/.q-system/agent-pipeline/bus/

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.venv/
htmlcov/
.coverage
coverage.xml

# Node
node_modules/

# XDG user data (never commit — lives outside repo)
# These are defensive entries in case someone symlinks them in
.config-kipi/
.data-kipi/
.state-kipi/
