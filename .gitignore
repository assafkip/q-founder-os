# Secrets (local settings with real tokens)
.env
*.env
.claude/settings.local.json

# OS
.DS_Store
Thumbs.db

# Output (generated daily, don't commit)
q-system/output/*.html
q-system/output/*.json
q-system/output/*.log
q-system/output/drafts/*
q-system/output/lead-gen/*
q-system/output/design-partner/*
q-system/output/marketing/linkedin/*
!**/.gitkeep

# Plans (auto-created by Claude Code)
.claude/plans/

# Session transcripts
*.jsonl
!q-system/memory/graph.jsonl

# Working memory (ephemeral, don't commit)
q-system/memory/working/*
!q-system/memory/working/.gitkeep
!q-system/memory/working/predictions.jsonl

# Node
node_modules/
