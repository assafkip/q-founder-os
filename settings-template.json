{
  "permissions": {
    "allow": [],
    "deny": [],
    "ask": [],
    "defaultMode": "acceptEdits"
  },
  "model": "opus",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "/q-morning|/q-scope|/q-plan",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/q-system/.q-system/diagnose-tools.sh\" 2>/dev/null | head -50",
            "timeout": 15000,
            "statusMessage": "Checking tool availability..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/q-system/hooks/session-start.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/q-system/.q-system/token-guard.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent|Bash|WebSearch|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/q-system/.q-system/tool-counter.sh\" 2>/dev/null || true",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "_INSTRUCTIONS_": "Uncomment and configure the servers you need. Replace YOUR_*_TOKEN placeholders with your actual tokens. Delete this _INSTRUCTIONS_ key when done.",

    "_notion_api": {
      "_comment": "Rename to 'notion_api' to enable. Get token from https://www.notion.so/my-integrations",
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "NOTION_TOKEN": "YOUR_NOTION_TOKEN"
      }
    },

    "_apify": {
      "_comment": "Rename to 'apify' to enable. Get token from https://console.apify.com/account#/integrations",
      "command": "npx",
      "args": [
        "-y",
        "@apify/actors-mcp-server",
        "--tools",
        "actors,apify/linkedin-profile-scraper,apify/linkedin-posts-scraper,apify/linkedin-connections-scraper,curious_coder/twitter-scraper,apify/reddit-scraper,apify/web-scraper"
      ],
      "env": {
        "APIFY_TOKEN": "YOUR_APIFY_TOKEN"
      }
    },

    "_reddit": {
      "_comment": "Rename to 'reddit' to enable",
      "command": "npx",
      "args": ["reddit-mcp-buddy"]
    },

    "_telegram": {
      "_comment": "Rename to 'telegram' to enable. Get credentials from https://my.telegram.org",
      "command": "telegram-mcp",
      "env": {
        "TG_APP_ID": "YOUR_TELEGRAM_APP_ID",
        "TG_API_HASH": "YOUR_TELEGRAM_API_HASH"
      }
    },

    "_playwright": {
      "_comment": "Rename to 'playwright' to enable. Browser automation alternative to Chrome MCP.",
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },

    "_threat-intel": {
      "_comment": "Rename to 'threat-intel' to enable. Threat intelligence feeds (VirusTotal, AbuseIPDB, OTX, etc). Requires server.py from your threat-intel-mcp repo.",
      "command": "uv",
      "args": ["run", "/path/to/threat-intel-mcp/server.py"],
      "env": {
        "VIRUSTOTAL_API_KEY": "YOUR_VIRUSTOTAL_KEY",
        "ABUSECH_AUTH_KEY": "YOUR_ABUSECH_KEY"
      }
    },

    "_osint-infra": {
      "_comment": "Rename to 'osint-infra' to enable. OSINT infrastructure lookup (WHOIS, DNS, cert transparency, Shodan). Requires server.py from your osint-infra-mcp repo.",
      "command": "uv",
      "args": ["run", "--with", "fastmcp>=2.0.0", "--with", "httpx>=0.27.0", "/path/to/osint-infra-mcp/server.py"]
    }
  },
  "toolConfigurations": {
    "Read": {
      "autoApprove": ["**/*"],
      "deny": [".env", "**/.env"]
    },
    "Edit": {
      "autoApprove": ["**/*"]
    },
    "Write": {
      "autoApprove": ["**/*"]
    },
    "mcp__notion__*": {
      "autoApprove": ["*"]
    },
    "mcp__notion_api__*": {
      "autoApprove": ["*"]
    },
    "mcp__apify__*": {
      "autoApprove": ["*"]
    },
    "mcp__threat-intel__*": {
      "autoApprove": ["*"]
    },
    "mcp__osint-infra__*": {
      "autoApprove": ["*"]
    }
  },
  "enabledPlugins": {
    "_INSTRUCTIONS_": "These are recommended plugins. Enable them in Claude Code with the plugin manager.",
    "document-skills@anthropic-agent-skills": true,
    "Notion@claude-plugins-official": true,
    "github@claude-plugins-official": true
  }
}
