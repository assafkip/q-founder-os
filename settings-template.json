{
  "extraKnownMarketplaces": {
    "kipi": {
      "source": {
        "source": "github",
        "repo": "assafkip/kipi-system"
      }
    }
  },
  "enabledPlugins": {
    "kipi-core@kipi": true
  },
  "outputStyle": "Founder OS",
  "autoMemoryEnabled": true,
  "cleanupPeriodDays": 30,
  "permissions": {
    "allow": [],
    "deny": [],
    "ask": [],
    "defaultMode": "acceptEdits"
  },
  "model": "opus",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/q-system/hooks/auto-update.sh\"",
            "timeout": 15,
            "statusMessage": "Checking for kipi updates..."
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/q-system/hooks/session-context.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/q-system/hooks/post-compact.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/q-system/hooks/stop-logger.sh\"",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/q-system/hooks/session-start.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/q-system/.q-system/token-guard.py\""
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "_INSTRUCTIONS_": "Uncomment and configure the servers you need. Replace YOUR_*_TOKEN placeholders with your actual tokens. Delete this _INSTRUCTIONS_ key when done.",

    "_notion_api": {
      "_comment": "Rename to 'notion_api' to enable. Get token from https://www.notion.so/my-integrations",
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "NOTION_TOKEN": "YOUR_NOTION_TOKEN"
      }
    },

    "_apify": {
      "_comment": "Rename to 'apify' to enable. Get token from https://console.apify.com/account#/integrations",
      "command": "npx",
      "args": [
        "-y",
        "@apify/actors-mcp-server",
        "--tools",
        "actors,apify/linkedin-profile-scraper,apify/linkedin-posts-scraper,apify/linkedin-connections-scraper,curious_coder/twitter-scraper,apify/reddit-scraper,apify/web-scraper"
      ],
      "env": {
        "APIFY_TOKEN": "YOUR_APIFY_TOKEN"
      }
    },

    "_reddit": {
      "_comment": "Rename to 'reddit' to enable. No API key needed.",
      "command": "uvx",
      "args": ["reddit-no-auth-mcp-server"]
    },

    "_telegram": {
      "_comment": "Rename to 'telegram' to enable. Get credentials from https://my.telegram.org",
      "command": "telegram-mcp",
      "env": {
        "TG_APP_ID": "YOUR_TELEGRAM_APP_ID",
        "TG_API_HASH": "YOUR_TELEGRAM_API_HASH"
      }
    },

    "_playwright": {
      "_comment": "Rename to 'playwright' to enable. Browser automation alternative to Chrome MCP.",
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    }
  },
  "toolConfigurations": {
    "Read": {
      "autoApprove": ["**/*"],
      "deny": [".env", "**/.env"]
    },
    "Edit": {
      "autoApprove": ["**/*"]
    },
    "Write": {
      "autoApprove": ["**/*"]
    },
    "mcp__notion__*": {
      "autoApprove": ["*"]
    },
    "mcp__notion_api__*": {
      "autoApprove": ["*"]
    },
    "mcp__apify__*": {
      "autoApprove": ["*"]
    }
  },
  "enabledPlugins": {
    "_INSTRUCTIONS_": "These are recommended plugins. Enable them in Claude Code with the plugin manager.",
    "document-skills@anthropic-agent-skills": true,
    "Notion@claude-plugins-official": true,
    "github@claude-plugins-official": true
  }
}
